# Required: Ziina payment API token
ZIINA_ACCESS_TOKEN=your_ziina_access_token_here

# Optional: set true for Ziina test mode
ZIINA_TEST_MODE=false

# Recommended for webhook authenticity validation
ZIINA_WEBHOOK_SECRET=your_ziina_webhook_secret_here

# Public app URL used for success/cancel redirects
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Delivery option A (recommended): direct email via Resend
RESEND_API_KEY=your_resend_api_key_here
ACCESS_EMAIL_FROM=ZUCCESS <no-reply@yourdomain.com>

# Delivery option B (alternative): external delivery webhook
# ACCESS_DELIVERY_WEBHOOK_URL=https://your-delivery-service.com/webhooks/game-access

# Optional overrides for delivered game links
SPARK_ACCESS_SAMAR_URL=https://samarnew2.netlify.app/
SPARK_ACCESS_IMAGINE_URL=https://khayalk.netlify.app/
SPARK_ACCESS_FAMILY_URL=https://swalefbitna.netlify.app/
